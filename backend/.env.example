ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
PORT=3001

# Legacy x402 wrapped token contract on Injective EVM (chain 1776)
# Native USDC supports EIP-3009 directly, so no WUSDC wrapper is needed.
WRAPPED_USDT_ADDRESS=0xfdd13887b73b868b87467a8d6480521d4ff82c4d

# Faucet private key for wallet that funds fresh accounts with INJ gas
FAUCET_PRIVATE_KEY=0x...

# Optional CCTP mint relayer key. Falls back to FAUCET_PRIVATE_KEY, then FACILITATOR_PRIVATE_KEY.
CCTP_RELAYER_PRIVATE_KEY=0x...

# x402 facilitator private key for settling micropayments on-chain
# If not set, chat API is free (dev mode). When set, /api/chat requires x402 payment.
FACILITATOR_PRIVATE_KEY=0x...
